# PostgreSQL Connection string
# Use Supabase's Supavisor Session-Mode Pooler (Port 5432) for IPv4 compatibility on Render:
# postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
DATABASE_URL="postgresql://postgres.jacnsvcwmhoicuuzmrmr:[YOUR_DB_PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Shared secret key for X-Internal-Secret validation (timing-attack protected)
INTERNAL_API_SECRET="your-generate-32-byte-hex-secret-here"

# Port to bind the server listener to (defaults to 8080 if not set)
PORT=8080
